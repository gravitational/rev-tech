# Teleport
TELEPORT_CLUSTER=yourcluster.teleport.sh
TELEPORT_USER=your-user@example.com

# Vault
VAULT_ADDR=https://your-vault-host:8200
VAULT_TOKEN=                          # root or admin token — only needed for setup cells
VAULT_CACERT=                         # path to Vault CA cert; leave empty to skip TLS verify (dev only)

# tbot (Step 8 optional)
TBOT_TOKEN=                           # tctl tokens add --type=bot --ttl=1h

# Appendix: Docker Vault setup (only needed if using the appendix)
VAULT_IP=127.0.0.1                    # machine IP the Vault container is reachable at; change for a remote VM
