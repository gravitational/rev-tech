# Required
ANTHROPIC_API_KEY=sk-ant-...
TELEPORT_PROXY=teleport.yourdomain.com

# LLM selection
LLM_PROVIDER=anthropic          # or: ollama, lmstudio
ANTHROPIC_MODEL=claude-sonnet-4-6
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://host.docker.internal:11434
LM_STUDIO_MODEL=qwen/qwen3-vl-4b
LM_STUDIO_BASE_URL=http://host.docker.internal:1234/v1
LM_STUDIO_API_KEY=lm-studio     # any non-empty string

# Teleport
TELEPORT_CLUSTER=yourdomain.com # often same as proxy

# Operator (set in K8s manifest, not .env)
# --namespace=a2a-demo
# --agent-label=type=agent
# --orchestrator-url=http://orchestrator:8080
