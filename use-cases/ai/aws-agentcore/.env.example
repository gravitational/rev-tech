# Teleport cluster hostname (no https://)
TELEPORT_CLUSTER=

# Join token for the app service agent (tctl tokens add --type=app --ttl=1h)
TELEPORT_TOKEN=

# Standard AWS Env Variables
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=us-east-1

# Unique prefix for all AWS resource names — change this so two users can share the same account
RESOURCE_PREFIX=teleport-demo
# Teleport cluster hostname (no https://)

# Tags applied to all Lambda functions; optional
TAG_CREATOR=
TAG_DEMO=teleport-agentcore

# TTI identity mapping (Notebook 04)
# TTI_APPLICATION_ARN and TTI_INSTANCE_ARN are written automatically by Phase 0
TTI_APPLICATION_ARN=
TTI_INSTANCE_ARN=
IDENTITY_CENTER_REGION=us-east-1

# Comma-separated emails of users who will run the demo (must match Teleport sub claim)
# Phase 0 creates these users in Identity Center and assigns them to the TTI application
DEMO_USER_EMAILS=
