# Teleport cluster hostname (no https://)
TELEPORT_CLUSTER=

# Join token for the app service agent (tctl tokens add --type=app --ttl=1h)
TELEPORT_TOKEN=

# Standard AWS Env Variables
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=us-east-1

# Unique prefix for all AWS resource names — change this so two users can share the same account
RESOURCE_PREFIX=teleport-demo
# Teleport cluster hostname (no https://)

# Tags applied to all Lambda functions; optional
TAG_CREATOR=
TAG_DEMO=teleport-agentcore
