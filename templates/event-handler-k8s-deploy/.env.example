
# Example aks deployment
# ── Kubernetes ────────────────────────────────────────────────────────────────
NAMESPACE="teleport-events"
BOT_NAME="event-handler"   # Teleport Machine ID bot name; also used for the role and token

# ── Teleport cluster ──────────────────────────────────────────────────────────
TELEPORT_ADDRESS="example.trial.teleport.sh:443"   # Proxy or Auth address
CLUSTER_NAME="example.trial.teleport.sh"            # tctl status → "Cluster:"

# ── Kubernetes join method ────────────────────────────────────────────────────
# eks / gcp / aks  kubernetes join via OIDC JWKS (auto-fetched from API server)
# kubernetes       self-hosted Teleport in-cluster (in_cluster verification)
# token            static token — auto-generated by deploy.sh, no manual setup needed
# bound_keypair    asymmetric keypair bound to this bot instance (Teleport 15+)
JOIN_METHOD="aks"

# ── Output target ─────────────────────────────────────────────────────────────
# fluent-bit   Deploy fluent/fluent-bit Helm chart (+ HAProxy 201→200 sidecar)
# fluentd      Deploy fluent/fluentd Helm chart    (returns 200 natively)
# none         No output deployed; set FLUENTD_URL + FLUENTD_SESSION_URL below
OUTPUT_TYPE="fluent-bit"

# Required when OUTPUT_TYPE=none — point at your existing endpoint
# FLUENTD_URL="https://my-fluentd.example.com:8888/teleport.events"
# FLUENTD_SESSION_URL="https://my-fluentd.example.com:8888/teleport.session.logs"
